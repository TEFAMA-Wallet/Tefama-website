# Network
SUI_NETWORK=testnet

# TEFAMA (from `sui client publish` + `vault::create`)
TEFAMA_PACKAGE_ID=0x...
VAULT_ID=0x...

# DeepBook SUI/USDC pool (discover via @mysten/deepbook-v3 SDK or an explorer)
POOL_ID=0x...

# Agent-owned Coin<DEEP> object used for fees (leftover is returned)
DEEP_COIN_ID=0x...

# Coin types
USDC_TYPE=0x...::usdc::USDC
SUI_TYPE=0x2::sui::SUI

# Agent scoped key (must be allowlisted via vault::add_agent). NOT the owner key.
AGENT_SECRET_KEY=suiprivkey1...

